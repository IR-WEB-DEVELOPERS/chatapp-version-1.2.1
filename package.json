{
  "name": "educhat",
  "version": "1.0.0",
  "description": "Real-time messaging app with Firebase, WebRTC calls, and group chats",
  "main": "chat.html",
  "scripts": {
    "start": "http-server -p 8080 -c-1 -o chat.html",
